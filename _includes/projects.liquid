<div class="col">
  <div class="card h-100 hoverable">
    <a href="{% if project.pdf %}{{ project.pdf | relative_url }}{% elsif project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}">
      {% if project.img %}
        {% include figure.liquid loading="eager" path=project.img sizes="250px" alt="project thumbnail" class="card-img-top" %}
      {% endif %}
      <div class="card-body">
        <h2 class="card-title">{{ project.title }}</h2>
      </div>
    </a>

    <p class="card-text">{{ project.description }}</p>

    <!-- BUTTONS HERE -->
    <div class="links ml-1 mr-1 mb-2">
      {% if project.abstract %}
        <button
          type="button"
          class="abstract btn btn-sm z-depth-0"
          data-toggle="modal"
          data-target="#abs-{{ project.title | slugify }}"
          title="Abstract"
        >
          Abs
        </button>
      {% endif %}

      {% if project.doi %}
        <a
          href="https://doi.org/{{ project.doi }}"
          class="btn btn-sm z-depth-0"
          role="button"
          target="_blank"
          rel="noopener"
        >
          DOI
        </a>
      {% endif %}

      {% if project.pdf %}
        <a
          href="{{ project.pdf | relative_url }}"
          class="btn btn-sm z-depth-0"
          role="button"
        >
          PDF
        </a>
      {% endif %}
    </div>
    <!-- END BUTTONS -->

    <div class="row ml-1 mr-1 p-0">
      {% if project.github %}
        <div class="github-icon">
          <div class="icon" data-toggle="tooltip" title="Code Repository">
            <a href="{{ project.github }}"><i class="fa-brands fa-github gh-icon"></i></a>
          </div>
          {% if project.github_stars %}
            <span class="stars" data-toggle="tooltip" title="GitHub Stars">
              <i class="fa-solid fa-star"></i>
              <span id="{{ project.github_stars }}-stars"></span>
            </span>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>
